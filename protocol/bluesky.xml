<?xml version="1.0"?>
<PropertyList>
<generic>
<output>
    <line_separator></line_separator>
    <var_separator>";"</var_separator>
    <!-- =====================  HEADER  ===================== -->
    <chunk>
        <format>FGFS</format>
    </chunk>
    <!-- =====================  GENERAL  ==================== -->
    <!-- [1] Simulator name -->
    <chunk>
        <node>/bluesky/sim_name</node>
        <name>bluesky name</name>
        <type>string</type>
        <format>%s</format>
    </chunk>
    <!-- [2] FlightGear Simulator IP -->
    <chunk>
        <node>/bluesky/sim_ip</node>
        <name>simulator IP address</name>
        <type>string</type>
        <format>%s</format>
    </chunk>
    <!-- [3] FlightGear Traffic receive port -->
    <chunk>
        <node>/bluesky/sim_traffic_recv_port</node>
        <name>simulator traffic recv port</name>
        <type>string</type>
        <format>%s</format>
    </chunk>
    <!-- [4] Simulator Telnet port -->
    <chunk>
        <node>/bluesky/sim_telnet_port</node>
        <name>simulator traffic telnet port</name>
        <type>string</type>
        <format>%s</format>
    </chunk>
    <!-- [5] Callsign -->
    <chunk>
        <node>/sim/multiplay/callsign</node>
        <name>callsign</name>
        <type>string</type>
        <format>%s</format>
    </chunk>
    <!-- [6] Aircraft type -->
    <chunk>
        <node>/aircraft/icao/type</node>
        <name>type</name>
        <type>string</type>
        <format>%s</format>
    </chunk>
    <!-- ===================  TRANSPONDER  ================== -->
    <!-- [7] Squawk code -->
    <chunk>
        <node>/instrumentation/transponder/id-code</node>
        <name>transponder</name>
        <type>int</type>
        <format>%d</format>
    </chunk>
    <!-- [8] Transponder Mode -->
    <chunk>
        <node>/instrumentation/transponder/inputs/knob-mode</node>
        <name>mode</name>
        <type>int</type>
        <format>%d</format>
    </chunk>
    <!-- [9] Transponder Ident -->
    <chunk>
        <node>/instrumentation/transponder/ident</node>
        <name>ident</name>
        <type>bool</type>
        <format>%d</format>
    </chunk>
    <!-- ====================  POSITION  ==================== -->
    <!-- [10] Latitude [deg] -->
    <chunk>
        <node>/position/latitude-deg</node>
        <name>latitude_deg</name>
        <type>float</type>
        <format>%03.8f</format>
    </chunk>
    <!-- [11] Longitude [deg] -->
    <chunk>
        <node>/position/longitude-deg</node>
        <name>longitude_deg</name>
        <type>float</type>
        <format>%f</format>
    </chunk>
    <!-- [12] Altitude [ft] -->
    <chunk>
        <node>/position/altitude-ft</node>
        <name>altitude </name>
        <type>float</type>
        <format>%f</format>
    </chunk>
    <!-- [13] Altitude AGL [ft] -->
    <chunk>
        <node>/position/altitude-agl-ft</node>
        <name>altitude-agl-ft</name>
        <type>float</type>
        <format>%03.8f</format>
    </chunk>
    <!-- =====================  SPEEDS  ===================== -->
    <!-- [14] True Airspeed [kts] -->
    <chunk>
        <node>/velocities/airspeed-kt</node>
        <name>airspeed_kts</name>
        <type>int</type>
        <format>%d</format>
    </chunk>
    <!-- [15] Vertical speed [ft/min] -->
    <chunk>
        <node>/velocities/vertical-speed-fps</node>
        <name>vertical_speed_fts</name>
        <type>float</type>
        <format>%04.2f</format>
    </chunk>
    <!-- ==================  ORIENTATION  =================== -->
    <!-- [16] AoA [deg] -->
    <chunk>
        <node>/orientation/alpha-deg</node>
        <name>alpha_deg</name>
        <type>float</type>
        <format>%03.3f</format>
    </chunk>
    <!-- [17] Sideslip [deg] -->
    <chunk>
        <node>/orientation/beta-deg</node>
        <name>beta_deg</name>
        <type>float</type>
        <format>%03.3f</format>
    </chunk>
    <!-- [18] Path angle [deg] -->
    <chunk>
        <node>/orientation/path-deg</node>
        <name>path_deg</name>
        <type>float</type>
        <format>%03.3f</format>
    </chunk>
    <!-- [19] Pitch [deg] -->
    <chunk>
        <node>/orientation/pitch-deg</node>
        <name>pitch_deg</name>
        <type>float</type>
        <format>%03.3f</format>
    </chunk>
    <!-- [20] Roll [deg] -->
    <chunk>
        <node>/orientation/roll-deg</node>
        <name>heading_deg</name>
        <type>float</type>
        <format>%03.3f</format>
    </chunk>
    <!-- [21] Yaw [deg] -->
    <chunk>
        <node>/orientation/yaw-deg</node>
        <name>heading_deg</name>
        <type>float</type>
        <format>%03.3f</format>
    </chunk>
    <!-- [22] True Heading [deg] -->
    <chunk>
        <node>/orientation/true-heading-deg</node>
        <name>heading_deg</name>
        <type>float</type>
        <format>%03.3f</format>
    </chunk>
</output>
</generic>
</PropertyList>