<?xml version="1.0"?>
<PropertyList>
<generic>
<output>
    <line_separator></line_separator>
    <var_separator>";"</var_separator>
    <!-- [0] BlueSky client name -->
    <chunk>
        <node>/bluesky/client/name</node>
        <name>name</name>
        <type>string</type>
        <format>%s</format>
    </chunk>
    <!-- [1] Callsign -->
    <chunk>
        <node>/sim/multiplay/callsign</node>
        <name>callsign</name>
        <type>string</type>
        <format>%s</format>
    </chunk>
    <!-- [2] Squawk code -->
    <chunk>
        <node>/instrumentation/transponder/id-code</node>
        <name>transponder</name>
        <type>int</type>
        <format>%d</format>
    </chunk>
    <!-- [3] Aircraft type -->
    <chunk>
        <node>/aircraft/icao/type</node>
        <name>type</name>
        <type>string</type>
        <format>%s</format>
    </chunk>
    <!-- [4] Transponder Ident -->
    <chunk>
        <node>/instrumentation/transponder/ident</node>
        <name>ident</name>
        <type>bool</type>
        <format>%d</format>
    </chunk>
    <!-- [5] Altitude ft -->
    <chunk>
        <node>/position/altitude-ft</node>
        <name>altitude_ft</name>
        <type>int</type>
        <format>%d</format>
    </chunk>
    <!-- [6] True Airspeed kts -->
    <chunk>
        <node>/velocities/airspeed-kt</node>
        <name>airspeed_kts</name>
        <type>int</type>
        <format>%d</format>
    </chunk>
    <!-- [7] Vertical speed ft/min -->
    <chunk>
        <node>/velocities/vertical-speed-fps</node>
        <name>vertical_speed_fts</name>
        <type>float</type>
        <format>%04.2f</format>
        <factor>60</factor>
    </chunk>
    <!-- [8] Heading deg -->
    <chunk>
        <node>/orientation/heading-deg</node>
        <name>heading_deg</name>
        <type>float</type>
        <format>%03.3f</format>
    </chunk>
    <!-- [9] Latitude deg -->
    <chunk>
        <node>/position/latitude-deg</node>
        <name>latitude_deg</name>
        <type>float</type>
        <format>%03.8f</format>
    </chunk>
    <!-- [10] Longitude deg -->
    <chunk>
        <node>/position/longitude-deg</node>
        <name>longitude_deg</name>
        <type>float</type>
        <format>%03.8f</format>
    </chunk>
</output>
</generic>
</PropertyList>